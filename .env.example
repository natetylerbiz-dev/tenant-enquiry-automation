TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# 3s keeps WhatsApp responses feeling snappy; raise if you're worried about
# Twilio rate limits on high account activity (untested above a few req/sec).
TWILIO_POLL_INTERVAL_MS=3000
TWILIO_SLOTS_TEMPLATE_SID=
AGENT_WHATSAPP_NUMBER=
AGENT_NAME=
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_CALENDAR_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GMAIL_POLL_INTERVAL_MS=60000
GMAIL_ENQUIRY_FROM=
GMAIL_ENQUIRY_TO=
ANTHROPIC_API_KEY=
CONFIDENCE_THRESHOLD=0.7
TEST_TENANT_PHONE_OVERRIDE=
# Set to "true" when testing solo with one WhatsApp number playing both
# tenant and agent, so a booking's agent notification doesn't land in the
# same thread you're using as the tenant. Calendar/Sheet updates and the
# tenant's own booking confirmation are unaffected.
TEST_SKIP_AGENT_BOOKING_NOTIFICATION=
